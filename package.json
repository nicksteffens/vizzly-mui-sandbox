{
  "name": "vizzly-mui-sandbox",
  "version": "1.0.0",
  "description": "Sandbox for testing Vizzly visual regression with MUI + Storybook",
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "vizzly:storybook": "storybook build && vizzly storybook ./storybook-static",
    "test": "cypress run --component -q",
    "test:dev": "cypress open --component"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@storybook/addon-docs": "^9.1.19",
    "@storybook/addon-links": "^9.1.19",
    "@storybook/react-vite": "^9.1.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vizzly-testing/cli": "^0.29.6",
    "@vizzly-testing/storybook": "^0.7.0",
    "cypress": "^15.11.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^9.1.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
